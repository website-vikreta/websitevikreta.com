# Google Analytics
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# EmailJS Configuration
# Get these values from your EmailJS dashboard: https://dashboard.emailjs.com/

# Your EmailJS Service ID (visible in the Services section of your dashboard)
NEXT_PUBLIC_EMAILJS_SERVICE_ID=your_service_id_here

# Your EmailJS Template ID (visible in the Email Templates section)
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=your_template_id_here

# Your EmailJS Public Key (visible in the Account settings)
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=your_public_key_here

# Note: NEXT_PUBLIC_ prefix makes these variables available in the browser.
# Do not put sensitive private keys here.

# EmailJS Template Variables
# Configure your EmailJS template to use these variable names:
# - from_name: the visitor's name
# - reply_to: the visitor's email address
# - message: the visitor's message text
